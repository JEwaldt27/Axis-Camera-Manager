<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AxisManager.ViewModels"
        xmlns:models="using:AxisManager.Models"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        x:Class="AxisManager.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="AXIS Camera Manager"
        Width="1200" Height="760"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="56,1,*,1,32">

    <!-- ══ Top Bar ══ -->
    <Grid Grid.Row="0" Background="{DynamicResource BgBrush}"
          ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
      <TextBlock Grid.Column="0" Text="◈ AXIS" Classes="title"
                 VerticalAlignment="Center" Margin="20,0,0,0"/>
      <TextBlock Grid.Column="1" Text="  CAMERA MANAGER"
                 Classes="dim" FontSize="12" VerticalAlignment="Center"/>

      <StackPanel Grid.Column="3" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="0,0,8,0" Spacing="8">
        <TextBlock Text="{Binding ConnectionStatus}"
                   Classes.success="{Binding IsConnected}"
                   Classes.warning="{Binding IsConnecting}"
                   Classes.danger="{Binding !IsConnected}"
                   FontSize="16" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding SelectedCamera.Ip, FallbackValue=''}"
                   Classes="dim" VerticalAlignment="Center"/>
      </StackPanel>

      <Button Grid.Column="4" Content="{Binding ThemeToggleGlyph}"
              Classes="ghost"
              Command="{Binding ToggleThemeCommand}"
              ToolTip.Tip="Toggle light / dark mode"
              FontSize="15" Padding="12,0"
              VerticalAlignment="Center"/>

      <Button Grid.Column="5" Content="⚙"
              Classes="ghost"
              Command="{Binding ToggleSettingsCommand}"
              FontSize="16" Padding="12,0"
              VerticalAlignment="Center"
              Margin="0,0,8,0"/>
    </Grid>

    <Rectangle Grid.Row="1" Fill="{DynamicResource AccentBrush}" Height="1"/>

    <!-- ══ Main Content ══ -->
    <Grid Grid.Row="2" ColumnDefinitions="300,1,*">

      <!-- ── Left Panel ── -->
      <Border Grid.Column="0" Background="{DynamicResource Bg2Brush}">
        <Grid RowDefinitions="Auto,1,*,1,Auto">

          <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                Background="{DynamicResource Bg2Brush}">
            <TextBlock Grid.Column="0" Text="DEVICES"
                       Classes="section-header"
                       VerticalAlignment="Center" Margin="16,12"/>
            <Button Grid.Column="1" Content="⟳  SCAN"
                    Classes="accent"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}"
                    Margin="8" Padding="12,6"/>
          </Grid>

          <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}" Height="1"/>

          <ListBox Grid.Row="2"
                   ItemsSource="{Binding Cameras}"
                   SelectedItem="{Binding SelectedCamera}"
                   Background="{DynamicResource Bg2Brush}"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" Height="44">
                  <StackPanel Grid.Column="0" VerticalAlignment="Center"
                              Spacing="2" Margin="4,0,0,0">
                    <TextBlock Text="{Binding Name}"
                               FontWeight="Bold" FontSize="10"
                               Foreground="{DynamicResource TextBrightBrush}"/>
                    <TextBlock Text="{Binding Ip}"
                               Classes="dim" FontSize="9"/>
                  </StackPanel>
                  <Border Grid.Column="1"
                          Background="{DynamicResource Bg3Brush}"
                          CornerRadius="3" Padding="6,2"
                          VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Status}"
                               FontSize="8"
                               Foreground="{DynamicResource TextDimBrush}"/>
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Rectangle Grid.Row="3" Fill="{DynamicResource BorderBrush}" Height="1"/>

          <StackPanel Grid.Row="4" Margin="12,10,12,12" Spacing="6">
            <TextBlock Text="ADD MANUALLY" Classes="label"/>
            <Grid ColumnDefinitions="*,8,Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding ManualIp}"
                       Watermark="192.168.x.x"
                       FontSize="10"/>
              <Button Grid.Column="2" Content="ADD"
                      Command="{Binding AddManualCommand}"
                      Padding="10,6" FontSize="10"/>
            </Grid>
          </StackPanel>

        </Grid>
      </Border>

      <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Width="1"/>

      <!-- ── Right Panel ── -->
      <Grid Grid.Column="2" RowDefinitions="Auto,1,Auto,Auto,Auto,1,*"
            Background="{DynamicResource BgBrush}">

        <!-- Camera header -->
        <Grid Grid.Row="0" Background="{DynamicResource Bg2Brush}"
              ColumnDefinitions="*,Auto" MinHeight="60">
          <StackPanel Grid.Column="0" VerticalAlignment="Center"
                      Margin="20,12" Spacing="4"
                      IsVisible="{Binding SelectedCamera, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding SelectedCamera.Name, FallbackValue='No Device Selected'}"
                       FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrightBrush}"/>
            <TextBlock FontSize="9" Classes="dim">
              <Run Text="{Binding SelectedCamera.Ip}"/>
              <Run Text="  ·  "/>
              <Run Text="{Binding SelectedCamera.Mac}"/>
            </TextBlock>
          </StackPanel>
          <TextBlock Grid.Column="0" Text="Select a device from the list"
                     Classes="dim" VerticalAlignment="Center" Margin="20,0"
                     IsVisible="{Binding SelectedCamera, Converter={x:Static ObjectConverters.IsNull}}"/>
        </Grid>

        <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}" Height="1"/>

        <!-- ── Settings Panel ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource Bg3Brush}"
                Padding="16,14" Margin="16,10,16,0"
                CornerRadius="4"
                IsVisible="{Binding ShowSettings}">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="DEFAULT CREDENTIALS"
                         Classes="section-header" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                         Text="Saved to %APPDATA%\AxisManager\settings.json"
                         Classes="dim" FontSize="8" VerticalAlignment="Center"/>
            </Grid>
            <Grid ColumnDefinitions="Auto,8,160,24,Auto,8,160,24,Auto,8,Auto">
              <TextBlock Grid.Column="0" Text="USERNAME" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="2" Text="{Binding DefaultUsername}" FontSize="10"/>
              <TextBlock Grid.Column="4" Text="PASSWORD" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="6" Text="{Binding DefaultPassword}"
                       PasswordChar="●" FontSize="10"/>
              <TextBlock Grid.Column="8" Text="AUTO-CONNECT" Classes="label"
                         VerticalAlignment="Center"/>
              <CheckBox Grid.Column="10" IsChecked="{Binding AutoConnect}"
                        VerticalAlignment="Center"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="SAVE DEFAULTS" Classes="accent"
                      Command="{Binding SaveSettingsCommand}" Padding="14,6"/>
              <Button Content="CANCEL" Classes="ghost"
                      Command="{Binding CancelSettingsCommand}" Padding="14,6"/>
              <TextBlock Text="Changes apply to new connections"
                         Classes="dim" FontSize="8"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ── First-Time Setup Panel ── -->
        <Border Grid.Row="3"
                Background="{DynamicResource Bg3Brush}"
                BorderBrush="{DynamicResource WarningBrush}"
                BorderThickness="0,0,0,2"
                Padding="16,14" Margin="16,8,16,0"
                CornerRadius="4"
                IsVisible="{Binding ShowSetupPanel}">
          <StackPanel Spacing="10">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="🆕" FontSize="16" VerticalAlignment="Center"/>
              <StackPanel Spacing="2">
                <TextBlock Text="NEW CAMERA DETECTED"
                           Foreground="{DynamicResource WarningBrush}"
                           FontSize="10" FontWeight="Bold"/>
                <TextBlock Text="This camera has no password set. Create a password to secure it and continue."
                           Classes="dim" FontSize="9"/>
              </StackPanel>
            </StackPanel>

            <!-- Password fields -->
            <Grid ColumnDefinitions="Auto,8,180,24,Auto,8,180">
              <TextBlock Grid.Column="0" Text="NEW PASSWORD" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="2"
                       Text="{Binding NewCamPassword}"
                       PasswordChar="●"
                       Watermark="min. 6 characters"
                       FontSize="10"/>
              <TextBlock Grid.Column="4" Text="CONFIRM" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="6"
                       Text="{Binding NewCamPassword2}"
                       PasswordChar="●"
                       Watermark="repeat password"
                       FontSize="10"/>
            </Grid>

            <!-- Error text -->
            <TextBlock Text="{Binding SetupErrorText}"
                       Foreground="{DynamicResource DangerBrush}"
                       FontSize="9" FontWeight="Bold"
                       IsVisible="{Binding SetupErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="SET PASSWORD &amp; CONNECT"
                      Classes="accent"
                      Command="{Binding CompleteSetupCommand}"
                      IsEnabled="{Binding !IsSettingUp}"
                      Padding="14,6"/>
              <Button Content="USE DEFAULT PASSWORD"
                      Classes="ghost"
                      Command="{Binding UseDefaultPasswordCommand}"
                      ToolTip.Tip="Fill both fields with your saved default password"
                      Padding="14,6"/>
              <Button Content="OPEN IN BROWSER"
                      Classes="ghost"
                      Command="{Binding OpenSetupInBrowserCommand}"
                      ToolTip.Tip="Opens the Axis web setup wizard in your browser"
                      Padding="14,6"/>
              <TextBlock Text="Setting up via browser is also supported"
                         Classes="dim" FontSize="8"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- ── Manual Auth Panel ── -->
        <Border Grid.Row="4"
                Background="{DynamicResource AuthBgBrush}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="0,0,0,2"
                Padding="16,12" Margin="16,8,16,0"
                CornerRadius="4"
                IsVisible="{Binding ShowManualAuth}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding AuthErrorText}"
                       Foreground="{DynamicResource DangerBrush}"
                       FontSize="9" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,8,160,24,Auto,8,160,24,Auto">
              <TextBlock Grid.Column="0" Text="USERNAME" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="2" Text="{Binding Username}" FontSize="10"/>
              <TextBlock Grid.Column="4" Text="PASSWORD" Classes="label"
                         VerticalAlignment="Center"/>
              <TextBox Grid.Column="6" Text="{Binding Password}"
                       PasswordChar="●" FontSize="10"/>
              <Button Grid.Column="8" Content="CONNECT"
                      Classes="accent"
                      Command="{Binding ConnectCommand}"
                      Padding="14,6" Margin="8,0,0,0"/>
            </Grid>
          </StackPanel>
        </Border>

        <Rectangle Grid.Row="5" Fill="{DynamicResource BorderBrush}"
                   Height="1" Margin="0,8,0,0"/>

        <!-- ── Tabs ── -->
        <TabControl Grid.Row="6" Padding="0"
                    Background="{DynamicResource BgBrush}">

          <!-- ═══ INFO TAB ═══ -->
          <TabItem Header="  INFO  ">
            <ScrollViewer Background="{DynamicResource BgBrush}">
              <StackPanel Margin="20" Spacing="16">
                <Border Classes="card" Padding="16">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="MODEL" Classes="label"/>
                        <TextBlock Text="{Binding InfoModel}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="SERIAL NUMBER" Classes="label"/>
                        <TextBlock Text="{Binding InfoSerial}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                    <Rectangle Fill="{DynamicResource BorderBrush}" Height="1"/>
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="FIRMWARE" Classes="label"/>
                        <TextBlock Text="{Binding InfoFirmware}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="SOC" Classes="label"/>
                        <TextBlock Text="{Binding InfoSoc}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                    <Rectangle Fill="{DynamicResource BorderBrush}" Height="1"/>
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="MAC ADDRESS" Classes="label"/>
                        <TextBlock Text="{Binding InfoMac}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="HOSTNAME" Classes="label"/>
                        <TextBlock Text="{Binding InfoHostname}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                    <Rectangle Fill="{DynamicResource BorderBrush}" Height="1"/>
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="VIDEO STREAMS" Classes="label"/>
                        <TextBlock Text="{Binding InfoStreams}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="STORAGE" Classes="label"/>
                        <TextBlock Text="{Binding InfoStorage}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Content="⬡  OPEN SNAPSHOT" Classes="ghost"
                          Command="{Binding OpenSnapshotCommand}"
                          IsEnabled="{Binding IsConnected}" Padding="14,8"/>
                  <Button Content="⬡  WEB INTERFACE" Classes="ghost"
                          Command="{Binding OpenWebInterfaceCommand}"
                          IsEnabled="{Binding SelectedCamera, Converter={x:Static ObjectConverters.IsNotNull}}"
                          Padding="14,8"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ═══ NETWORK TAB ═══ -->
          <TabItem Header="  NETWORK  ">
            <ScrollViewer Background="{DynamicResource BgBrush}">
              <StackPanel Margin="20" Spacing="14">
                <TextBlock Text="CURRENT NETWORK CONFIG" Classes="section-header"/>
                <Border Classes="card" Padding="16">
                  <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="IP ADDRESS" Classes="label"/>
                        <TextBlock Text="{Binding CurIp}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="SUBNET MASK" Classes="label"/>
                        <TextBlock Text="{Binding CurSubnet}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,32,*">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="DEFAULT GATEWAY" Classes="label"/>
                        <TextBlock Text="{Binding CurGw}" Classes="value"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="MODE" Classes="label"/>
                        <TextBlock Text="{Binding CurMode}" Classes="value"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
                <TextBlock Text="SET STATIC IP" Classes="section-header" Margin="0,6,0,0"/>
                <Border Classes="card" Padding="16">
                  <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,20,*">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="IP ADDRESS" Classes="label"/>
                        <TextBox Text="{Binding NewIp}" Watermark="192.168.x.x"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="SUBNET MASK" Classes="label"/>
                        <TextBox Text="{Binding NewSubnet}" Watermark="255.255.255.0"/>
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,20,*">
                      <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="DEFAULT GATEWAY" Classes="label"/>
                        <TextBox Text="{Binding NewGw}" Watermark="192.168.x.1"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="HOSTNAME" Classes="label"/>
                        <TextBox Text="{Binding NewHostname}" Watermark="axis-xxxxxx"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Content="⬡  APPLY STATIC IP" Classes="accent"
                          Command="{Binding ApplyStaticIpCommand}"
                          IsEnabled="{Binding IsConnected}" Padding="16,8"/>
                  <Button Content="⬡  SET DHCP" Classes="warning"
                          Command="{Binding ApplyDhcpCommand}"
                          IsEnabled="{Binding IsConnected}" Padding="16,8"/>
                  <Button Content="⬡  RESTART CAMERA" Classes="danger"
                          Command="{Binding RestartCameraCommand}"
                          IsEnabled="{Binding IsConnected}" Padding="16,8"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <!-- ═══ STREAMS TAB ═══ -->
          <TabItem Header="  STREAMS  ">
            <Grid RowDefinitions="Auto,*" Background="{DynamicResource BgBrush}">
              <TextBlock Grid.Row="0" Text="RTSP / HTTP STREAM URLS"
                         Classes="section-header" Margin="20,16,0,8"/>
              <ScrollViewer Grid.Row="1" Margin="16,0,16,16">
                <ItemsControl ItemsSource="{Binding Streams}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:StreamInfo">
                      <Border Background="{DynamicResource Bg3Brush}"
                              CornerRadius="4" Padding="12,8" Margin="0,3">
                        <Grid ColumnDefinitions="36,*,90,90">
                          <Border Grid.Column="0"
                                  Background="{DynamicResource Bg2Brush}"
                                  CornerRadius="3" Padding="6,3"
                                  VerticalAlignment="Center">
                            <TextBlock Text="{Binding Index}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center"/>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="2"
                                      VerticalAlignment="Center" Margin="8,0">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="Bold" FontSize="9"
                                       Foreground="{DynamicResource TextBrightBrush}"/>
                            <TextBlock Text="{Binding RtspUrl}"
                                       Classes="dim" FontSize="8"
                                       TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <Button Grid.Column="2" Content="COPY RTSP"
                                  Classes="ghost" FontSize="8"
                                  Padding="8,4" Margin="4,0"
                                  Tag="{Binding RtspUrl}"
                                  Click="OnCopyRtspClick"/>
                          <Button Grid.Column="3" Content="COPY HTTP"
                                  Classes="ghost" FontSize="8" Padding="8,4"
                                  Tag="{Binding HttpUrl}"
                                  Click="OnCopyHttpClick"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </TabItem>

          <!-- ═══ ALL PARAMS TAB ═══ -->
          <TabItem Header="  ALL PARAMS  ">
            <Grid RowDefinitions="Auto,*" Background="{DynamicResource BgBrush}">
              <Grid Grid.Row="0" ColumnDefinitions="Auto,8,*,8,Auto"
                    Margin="16,12,16,8">
                <TextBlock Grid.Column="0" Text="FILTER"
                           Classes="label" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Text="{Binding ParamFilter}"
                         Watermark="Search parameters…" FontSize="10"/>
                <Button Grid.Column="4" Content="REFRESH" Classes="ghost"
                        Command="{Binding RefreshParamsCommand}"
                        IsEnabled="{Binding IsConnected}" Padding="10,6"/>
              </Grid>
              <dg:DataGrid Grid.Row="1"
                           ItemsSource="{Binding FilteredParams}"
                           AutoGenerateColumns="False"
                           CanUserReorderColumns="False"
                           CanUserResizeColumns="True"
                           CanUserSortColumns="True"
                           IsReadOnly="True"
                           Margin="16,0,16,16">
                <dg:DataGrid.Columns>
                  <dg:DataGridTextColumn Header="PARAMETER"
                                         Binding="{Binding Key}" Width="2*"/>
                  <dg:DataGridTextColumn Header="VALUE"
                                         Binding="{Binding Value}" Width="*"/>
                </dg:DataGrid.Columns>
              </dg:DataGrid>
            </Grid>
          </TabItem>

        </TabControl>
      </Grid>
    </Grid>

    <Rectangle Grid.Row="3" Fill="{DynamicResource BorderBrush}" Height="1"/>

    <!-- ══ Status Bar ══ -->
    <Grid Grid.Row="4" Background="{DynamicResource BgBrush}"
          ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                 Classes="dim" FontSize="9"
                 VerticalAlignment="Center" Margin="16,0"/>
      <TextBlock Grid.Column="1"
                 Text="AXIS Camera Manager  ·  .NET 8 / Avalonia"
                 Classes="dim" FontSize="9"
                 VerticalAlignment="Center" Margin="0,0,16,0"/>
    </Grid>

  </Grid>
</Window>
